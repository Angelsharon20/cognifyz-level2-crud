# //.env  — copy this to .env and fill in your values
# Never commit .env to source control.

# MongoDB connection string
# Local:  mongodb://127.0.0.1:27017/producthub
# Atlas:  mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/producthub?retryWrites=true&w=majority
MONGO_URI=mongodb://127.0.0.1:27017/producthub

# HTTP port (optional, defaults to 3000)
PORT=3000
